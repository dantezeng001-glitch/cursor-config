# Ignore everything in .cursor by default
*

# Allow descending into rules/ and skills/ only
!rules/
!rules/**
!skills/
!skills/**

# Exclude any timestamped backup folders inside skills/ (e.g. ppt-agent.bak-20260509)
skills/*.bak-*/
skills/*.bak-*/**
skills/**/*.bak-*/
skills/**/*.bak-*/**

# Allow repo metadata files at the root
!README.md
!.gitignore
